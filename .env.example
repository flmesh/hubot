# ─── Required ────────────────────────────────────────────────────────────────
# Discord bot token obtained from https://discord.com/developers/applications
# The container will refuse to start without this value.
HUBOT_DISCORD_TOKEN=your-discord-bot-token-here

# ─── Bot identity ─────────────────────────────────────────────────────────────
# The name Hubot listens to (prefix used in commands, e.g. "hubot ping")
HUBOT_NAME=hubot

# Human-readable metadata – used in help output
HUBOT_OWNER=Your Name <you@example.com>
HUBOT_DESCRIPTION=A Hubot instance for our Discord server

# ─── Logging ──────────────────────────────────────────────────────────────────
# One of: debug | info | warning | error (default: info)
HUBOT_LOG_LEVEL=info
