# ─── Required ────────────────────────────────────────────────────────────────
# Discord bot token obtained from https://discord.com/developers/applications
# The container will refuse to start without this value.
HUBOT_DISCORD_TOKEN=your-discord-bot-token-here

# ─── Bot identity ─────────────────────────────────────────────────────────────
# The name Hubot listens to (prefix used in commands, e.g. "hubot ping")
HUBOT_NAME=hubot

# Human-readable metadata – used in help output
HUBOT_OWNER=Your Name <you@example.com>
HUBOT_DESCRIPTION=A Hubot instance for our Discord server

# ─── Logging ──────────────────────────────────────────────────────────────────
# One of: debug | info | warning | error (default: info)
HUBOT_LOG_LEVEL=info

# ─── Loki query settings (for `hubot node logs ...`) ─────────────────────────
# Loki API base URL used by the node logs command.
# Example values:
#   http://localhost:3100            (Hubot running on host)
#   http://host.docker.internal:3100 (Hubot running in Docker, Loki on host)
#   http://loki:3100                 (Hubot and Loki on same Docker network)
LOKI_URL=http://host.docker.internal:3100

# Optional basic auth for Loki API
LOKI_USERNAME=
LOKI_PASSWORD=

# Optional short-lived Redis cache for `node.logs` replies, in seconds.
# Set to 0 to disable caching.
NODE_LOGS_CACHE_TTL_SECONDS=30

# ─── MongoDB settings (for `hubot mqtt ...`) ─────────────────────────────────
# Preferred discrete settings. Hubot will construct the MongoDB URI and safely
# encode the username and password.
MONGO_HOST=host.docker.internal
MONGO_PORT=27017
MONGO_USERNAME=hubot_rw
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=mqtt

# Optional direct connection string override used as-is when set.
# Example:
#   mongodb://hubot_rw:password@host.docker.internal:27017/mqtt?authSource=mqtt
MONGO_URL=

# Database name used by the MQTT account commands.
MONGO_DB_NAME=mqtt

# Discord admin role configuration for MQTT admin-only commands.
# Guild ID is used to verify admin role membership for commands sent by DM.
# HUBOT_DISCORD_PERMISSION_GUILD_ID can be used as a generic command-bus
# permission guild override. It defaults to MQTT_ADMIN_GUILD_ID when unset.
HUBOT_DISCORD_PERMISSION_GUILD_ID=
MQTT_ADMIN_GUILD_ID=
MQTT_ADMIN_ROLE_IDS=

# ─── EMQX API settings (for `hubot mqtt ...`) ────────────────────────────────
# Base URL of the EMQX HTTP API (v5).
# Example: http://emqx:18083
EMQX_API_URL=http://emqx:18083

# EMQX API key and secret created in the EMQX dashboard under
# System → API Keys. Used as HTTP Basic Auth credentials.
EMQX_API_KEY=
EMQX_API_SECRET=

# Default number of days a client ban is active (default: 7).
EMQX_BAN_DEFAULT_DAYS=7
