{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "semanticCommitType": "fix",
  "semanticCommitScope": "deps",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "semanticCommitType": "feat"
    }
  ]
}
